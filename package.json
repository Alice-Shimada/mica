{
  "name": "mica",
  "version": "0.1.0",
  "description": "Local MCP bridge for controlling active Mathematica notebooks through a Wolfram Paclet Palette.",
  "type": "module",
  "bin": {
    "mica": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts --bridge-only",
    "dev:mcp": "tsx src/index.ts",
    "dev:bun": "bun run src/bun/index.ts --bridge-only",
    "dev:bun:mcp": "bun run src/bun/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
