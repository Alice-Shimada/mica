{
  "name": "mica",
  "version": "0.1.0",
  "description": "Local MCP bridge for controlling active Mathematica notebooks through a Wolfram Paclet Palette.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alice-Shimada/mica.git"
  },
  "bugs": {
    "url": "https://github.com/Alice-Shimada/mica/issues"
  },
  "homepage": "https://github.com/Alice-Shimada/mica#readme",
  "keywords": [
    "mcp",
    "wolfram",
    "mathematica",
    "notebook",
    "agent"
  ],
  "bin": {
    "mica": "dist/src/cli/index.js"
  },
  "files": [
    "dist/src",
    "src/bun/index.ts",
    "paclet",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "scripts/install.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:mcp": "node dist/src/bun/index.js",
    "dev:mcp": "tsx src/bun/index.ts",
    "dev:bridge": "tsx src/bun/index.ts --bridge-only",
    "dev:bun:mcp": "bun run src/bun/index.ts",
    "dev:bun": "bun run src/bun/index.ts --bridge-only",
    "dev:legacy": "tsx src/index.ts --bridge-only",
    "dev:legacy:mcp": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
